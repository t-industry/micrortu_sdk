{
    "firmware_version": "{{firmware_version}}",
    "version": [0, 0, 1],
    "base_control_period_milliseconds": 100,
    "address_space": [
        { "name": "a", "ca": [1, 1], "ioa": [0, 0, 1], "ti": 1, "initial_value": 0.0 },
        { "name": "b", "ca": [1, 1], "ioa": [0, 0, 2], "ti": 1, "initial_value": 1.0 },
    ],
    "process_list": [
        {
            "name": "p1",
            "control_period_multiplier": 1,
            "block_instances": [
                {
                    "name": "flipper",
                    "type_id": "xor_1_1",
                    "port_binding": {
                        "a": ["a", "b"],
                        "y": "a",
                    },
                }
            ]
        },
    ],
    "local_io": {
        "A5": { "range": "NI1000" },
        "A6": { "range": "NI1000" },
        "U1": { "range": "0_10V" },
        "U2": { "range": "0_10V" }
    }
}
